        }
      ],
      "failure": {
        "class": "NO_DURABLE_DELTA or null",
        "fingerprint": "hex or null",
        "diagnosis": "mechanical and agent diagnosis",
        "evidence_refs": ["path"]
      },
      "resources": {
        "claude_session_id": "UUID",
        "agent_restarts": 0,
        "completed_iterations_in_grant": 3,
